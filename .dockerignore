# Local virtual environment (never ship this into the image)
venv/
env/
.venv/

# Notebooks and exploratory work aren't needed at runtime
notebooks/
.ipynb_checkpoints/

# VCS / editor
.git/
.gitignore
.vscode/

# Regenerated by the training pipeline; keep the image build reproducible
# from source instead of stale local runs
artifacts/
logs/

# Python cruft
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/

# OS cruft
.DS_Store
Thumbs.db
